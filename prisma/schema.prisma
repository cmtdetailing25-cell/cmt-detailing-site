// Prisma schema for CMT Detailing
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Existing enums ───────────────────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  BOOKED
  LOST
}

enum ClientStatus {
  LEAD
  ACTIVE
  MAINTENANCE
  INACTIVE
}

// ─── Social Media Agent enums ─────────────────────────────────────────────────

enum SocialContentType {
  POST
  REEL
  STORY
}

enum SocialContentStatus {
  IDEA
  DRAFT
  NEEDS_APPROVAL
  APPROVED
  SCHEDULED
  POSTED
  ARCHIVED
}

enum SocialContentSource {
  AUTO_AGENT
  MANUAL
}

enum SocialAgentRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─── Client / Vehicle / DetailJob models ─────────────────────────────────────

model Client {
  id         String       @id @default(cuid())
  firstName  String
  lastName   String
  fullName   String
  email      String?
  phone      String?
  city       String?
  state      String?
  notes      String?
  tags       String[]     @default([])
  leadSource String?
  status     ClientStatus @default(LEAD)
  isVip      Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  vehicles   Vehicle[]
  detailJobs DetailJob[]
}

model Vehicle {
  id        String   @id @default(cuid())
  clientId  String
  year      String
  make      String
  model     String
  trim      String?
  color     String?
  plate     String?
  vin       String?
  nickname  String?
  notes     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  detailJobs DetailJob[]
}

model DetailJob {
  id            String    @id @default(cuid())
  clientId      String?
  vehicleId     String?
  title         String
  slug          String?
  serviceType   String?
  jobDate       DateTime?
  location      String?
  description   String?
  internalNotes String?
  socialSummary String?
  isSocialReady Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client       Client?              @relation(fields: [clientId], references: [id])
  vehicle      Vehicle?             @relation(fields: [vehicleId], references: [id])
  photos       SitePhoto[]
  socialDrafts SocialContentDraft[]
}

// ─── Existing models ──────────────────────────────────────────────────────────

model Lead {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  status    LeadStatus @default(NEW)

  fullName  String
  phone     String
  email     String

  vehicleYear  String
  vehicleMake  String
  vehicleModel String

  serviceRequested String

  town          String
  preferredDate String
  preferredTime String
}

model SitePhoto {
  id           String   @id @default(cuid())
  title        String
  caption      String?
  imageUrl     String
  category     String
  label        String?
  isFeatured   Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // ─── Media Intelligence ───────────────────────────────────────────────────
  socialTitle            String?
  socialNotes            String?
  contentScore           Int       @default(0)
  qualityScore           Int       @default(0)
  marketingScore         Int       @default(0)
  isSocialReady          Boolean   @default(false)
  isReelCandidate        Boolean   @default(false)
  isPostCandidate        Boolean   @default(false)
  isBeforeAfterCandidate Boolean   @default(false)
  isFavoriteForSocial    Boolean   @default(false)
  contentTags            String[]  @default([])
  serviceType            String?
  visualCategory         String?
  contentAngle           String?
  seasonalRelevance      String?
  lastReviewedForSocial  DateTime?
  reviewedByAgent        Boolean   @default(false)

  detailJobId String?
  detailJob   DetailJob?           @relation(fields: [detailJobId], references: [id])

  socialMedia SocialContentMedia[]
}

// ─── Social Media Agent models ────────────────────────────────────────────────

model SocialAgentRun {
  id            String               @id @default(cuid())
  status        SocialAgentRunStatus @default(PENDING)
  weekStartDate DateTime
  weekEndDate   DateTime
  postsTarget   Int                  @default(3)
  reelsTarget   Int                  @default(2)
  draftsCreated  Int                  @default(0)
  postsGenerated Int                  @default(0)
  reelsGenerated Int                  @default(0)
  mediaReviewed  Int                  @default(0)
  startedAt      DateTime?
  completedAt   DateTime?
  errorMessage  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  drafts SocialContentDraft[]
}

model SocialContentDraft {
  id              String              @id @default(cuid())
  type            SocialContentType
  status          SocialContentStatus @default(IDEA)
  source          SocialContentSource @default(MANUAL)
  title           String
  caption         String?
  hashtags        String?
  hook            String?
  notes           String?
  scheduledFor    DateTime?
  postedAt        DateTime?
  instagramPostId String?
  generatedAt     DateTime?
  approvedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  agentRunId  String?
  agentRun    SocialAgentRun? @relation(fields: [agentRunId], references: [id])

  detailJobId String?
  detailJob   DetailJob?      @relation(fields: [detailJobId], references: [id])

  media SocialContentMedia[]
}

model SocialContentMedia {
  id          String   @id @default(cuid())
  draftId     String
  sitePhotoId String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  draft     SocialContentDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  sitePhoto SitePhoto          @relation(fields: [sitePhotoId], references: [id])
}

model SocialTrendIdea {
  id              String   @id @default(cuid())
  title           String
  source          String
  category        String
  notes           String?
  popularityScore Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SocialAgentSettings {
  id                    String    @id @default(cuid())
  weeklyPostTarget      Int       @default(3)
  weeklyReelTarget      Int       @default(2)
  defaultHashtags       String?
  brandVoice            String?
  approvalRequired      Boolean   @default(true)
  autoGenerateEnabled   Boolean   @default(false)
  preferredPostingDays  String?
  preferredPostingTimes String?
  lastGeneratedAt       DateTime?
  nextGenerationAt      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}
