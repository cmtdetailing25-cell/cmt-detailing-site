// Prisma schema for CMT Detailing
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Existing enums ───────────────────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  BOOKED
  LOST
}

enum ClientStatus {
  LEAD
  ACTIVE
  MAINTENANCE
  INACTIVE
}

// ─── Social Media Agent enums ─────────────────────────────────────────────────

enum SocialContentType {
  POST
  REEL
  STORY
}

enum SocialContentStatus {
  IDEA
  DRAFT
  NEEDS_APPROVAL
  APPROVED
  SCHEDULED
  POSTED
  ARCHIVED
}

enum SocialContentSource {
  AUTO_AGENT
  MANUAL
}

enum SocialAgentRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum TrendCategory {
  MOBILE_DETAILING
  CERAMIC_COATING
  PAINT_CORRECTION
  INTERIOR_DETAILING
  EXTERIOR_DETAILING
  BEFORE_AFTER_TRANSFORMATIONS
  SEASONAL_PROTECTION
  CUSTOMER_EDUCATION
  LUXURY_CAR_CARE
  LOCAL_BUSINESS_MARKETING
}

enum TrendType {
  HASHTAG
  CONTENT_FORMAT
  CAPTION_STYLE
  REEL_STRUCTURE
  AUDIO_IDEA
  SEASONAL_TOPIC
  LOCAL_TREND
  COMPETITOR_INSPIRATION
}

enum TrendResearchRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─── Client / Vehicle / DetailJob models ─────────────────────────────────────

model Client {
  id         String       @id @default(cuid())
  firstName  String
  lastName   String
  fullName   String
  email      String?
  phone      String?
  city       String?
  state      String?
  notes      String?
  tags       String[]     @default([])
  leadSource String?
  status     ClientStatus @default(LEAD)
  isVip      Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  vehicles   Vehicle[]
  detailJobs DetailJob[]
  leads      Lead[]
  campaigns  MarketingCampaign[]
}

model Vehicle {
  id        String   @id @default(cuid())
  clientId  String
  year      String
  make      String
  model     String
  trim      String?
  color     String?
  plate     String?
  vin       String?
  nickname  String?
  notes     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  detailJobs DetailJob[]
  campaigns  MarketingCampaign[]
}

model DetailJob {
  id             String    @id @default(cuid())
  clientId       String?
  vehicleId      String?
  title          String
  slug           String?
  serviceType    String?
  jobDate        DateTime?
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  scheduleStatus String?
  location       String?
  description    String?
  internalNotes  String?
  socialSummary  String?
  price          Float?
  leadId         String?
  isSocialReady  Boolean   @default(false)
  isFeatured     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client       Client?              @relation(fields: [clientId], references: [id])
  vehicle      Vehicle?             @relation(fields: [vehicleId], references: [id])
  lead         Lead?                @relation(fields: [leadId], references: [id])
  photos       SitePhoto[]
  socialDrafts SocialContentDraft[]
  campaigns    MarketingCampaign[]
}

// ─── Existing models ──────────────────────────────────────────────────────────

model Lead {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  status    LeadStatus @default(NEW)

  fullName  String
  phone     String
  email     String

  vehicleYear  String
  vehicleMake  String
  vehicleModel String

  serviceRequested String

  town             String
  preferredDate    String
  preferredTime    String
  vehicleCondition String?
  notes            String?

  clientId   String?
  client     Client?     @relation(fields: [clientId], references: [id])
  detailJobs DetailJob[]
}

// ─── Admin Notifications ──────────────────────────────────────────────────────

model AdminNotification {
  id               String   @id @default(cuid())
  type             String
  title            String
  message          String
  isRead           Boolean  @default(false)
  isArchived       Boolean  @default(false)
  actionUrl        String?
  relatedBookingId String?
  relatedClientId  String?
  relatedVehicleId String?
  relatedJobId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SitePhoto {
  id           String   @id @default(cuid())
  title        String
  caption      String?
  imageUrl     String
  category     String
  label        String?
  isFeatured   Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // ─── Media Intelligence ───────────────────────────────────────────────────
  socialTitle            String?
  socialNotes            String?
  contentScore           Int       @default(0)
  qualityScore           Int       @default(0)
  marketingScore         Int       @default(0)
  isSocialReady          Boolean   @default(false)
  isReelCandidate        Boolean   @default(false)
  isPostCandidate        Boolean   @default(false)
  isBeforeAfterCandidate Boolean   @default(false)
  isFavoriteForSocial    Boolean   @default(false)
  contentTags            String[]  @default([])
  serviceType            String?
  visualCategory         String?
  contentAngle           String?
  seasonalRelevance      String?
  lastReviewedForSocial  DateTime?
  reviewedByAgent        Boolean   @default(false)

  detailJobId String?
  detailJob   DetailJob?           @relation(fields: [detailJobId], references: [id])

  socialMedia SocialContentMedia[]
}

// ─── Social Media Agent models ────────────────────────────────────────────────

model SocialAgentRun {
  id            String               @id @default(cuid())
  status        SocialAgentRunStatus @default(PENDING)
  weekStartDate DateTime
  weekEndDate   DateTime
  postsTarget   Int                  @default(3)
  reelsTarget   Int                  @default(2)
  draftsCreated  Int                  @default(0)
  postsGenerated Int                  @default(0)
  reelsGenerated Int                  @default(0)
  mediaReviewed  Int                  @default(0)
  startedAt      DateTime?
  completedAt   DateTime?
  errorMessage  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  drafts SocialContentDraft[]
}

model SocialContentDraft {
  id              String              @id @default(cuid())
  type            SocialContentType
  status          SocialContentStatus @default(IDEA)
  source          SocialContentSource @default(MANUAL)
  title           String
  caption         String?
  hashtags        String?
  hook            String?
  notes           String?
  scheduledFor    DateTime?
  postedAt        DateTime?
  instagramPostId String?
  generatedAt     DateTime?
  approvedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  agentRunId  String?
  agentRun    SocialAgentRun? @relation(fields: [agentRunId], references: [id])

  detailJobId String?
  detailJob   DetailJob?      @relation(fields: [detailJobId], references: [id])

  trendInsightId String?
  trendInsight   TrendInsight? @relation(fields: [trendInsightId], references: [id])

  media SocialContentMedia[]
}

model SocialContentMedia {
  id          String   @id @default(cuid())
  draftId     String
  sitePhotoId String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  draft     SocialContentDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  sitePhoto SitePhoto          @relation(fields: [sitePhotoId], references: [id])
}

model SocialTrendIdea {
  id              String   @id @default(cuid())
  title           String
  source          String
  category        String
  notes           String?
  popularityScore Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SocialAgentSettings {
  id                    String    @id @default(cuid())
  weeklyPostTarget      Int       @default(3)
  weeklyReelTarget      Int       @default(2)
  defaultHashtags       String?
  brandVoice            String?
  approvalRequired      Boolean   @default(true)
  autoGenerateEnabled   Boolean   @default(false)
  preferredPostingDays  String?
  preferredPostingTimes String?
  lastGeneratedAt       DateTime?
  nextGenerationAt      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ─── Trend Research ───────────────────────────────────────────────────────────

model TrendResearchSettings {
  id                 String   @id @default(cuid())
  isEnabled          Boolean  @default(false)
  researchFrequency  String   @default("manual")
  targetPlatforms    String[] @default([])
  targetHashtags     String[] @default([])
  competitorAccounts String[] @default([])
  serviceCategories  String[] @default([])
  locationKeywords   String[] @default([])
  minConfidenceScore Int      @default(6)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TrendResearchRun {
  id             String                 @id @default(cuid())
  status         TrendResearchRunStatus @default(PENDING)
  startedAt      DateTime?
  completedAt    DateTime?
  trendsFound    Int                    @default(0)
  sourcesChecked Int                    @default(0)
  errorMessage   String?
  notes          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

// ─── Trend Intelligence ───────────────────────────────────────────────────────
//
// TrendSource: named origin (Meta Creator Studio, manual entry, RSS feed, etc.)
// TrendInsight: an actionable trend idea with hooks, angles, hashtags, and scores.
//   Insights are referenced by the Weekly Agent v2 to shape caption angles.
//
// Future research sources (not yet implemented):
//   - Meta/Instagram Graph API (official, safest)
//   - Approved third-party trend providers (e.g. Metricool, Later)
//   - Public RSS/web sources where terms of service permit
//   - Manual entry (current phase)
// Do NOT add scraping or browser automation to these models.

model TrendSource {
  id        String   @id @default(cuid())
  name      String
  type      String
  url       String?
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  insights TrendInsight[]
}

model TrendInsight {
  id                  String        @id @default(cuid())
  title               String
  platform            String
  source              String?
  category            TrendCategory
  trendType           TrendType
  summary             String?
  suggestedUse        String?
  exampleHook         String?
  exampleCaptionAngle String?
  hashtags            String?
  confidenceScore     Int           @default(5)
  popularityScore     Int           @default(5)
  isActive            Boolean       @default(true)
  expiresAt           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  trendSourceId String?
  trendSource   TrendSource? @relation(fields: [trendSourceId], references: [id])

  drafts    SocialContentDraft[]
  campaigns MarketingCampaign[]
}

// ─── Marketing Automation enums ───────────────────────────────────────────────

enum CampaignType {
  ORGANIC_POST
  REEL
  VIDEO_AD
  META_AD
  STORY
  CAROUSEL
}

enum CampaignStatus {
  IDEA
  TREND_REVIEW
  STRATEGY_PENDING_APPROVAL
  CREATIVE_PENDING
  CREATIVE_PENDING_APPROVAL
  APPROVED_TO_PUBLISH
  PUBLISHED
  ACTIVE_AD
  COMPLETED
  ARCHIVED
  FAILED
}

enum AssetType {
  IMAGE
  CANVA_DESIGN
  REMOTION_VIDEO
  FINAL_VIDEO
  FINAL_IMAGE
  COPY_DOC
}

enum AssetProvider {
  VERCEL_BLOB
  CANVA
  REMOTION
  META
  N8N
}

enum AssetStatus {
  PENDING
  READY
  APPROVED
  REJECTED
}

enum AutomationWorkflowType {
  TREND_RESEARCH
  CLAUDE_STRATEGY
  CANVA_ASSET_CREATION
  REMOTION_VIDEO_CREATION
  META_PUBLISHING
  META_AD_CREATION
  PERFORMANCE_SYNC
}

enum AutomationRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─── Marketing Automation models ──────────────────────────────────────────────

model AutomationSettings {
  id                         String   @id @default(cuid())
  n8nBaseUrl                 String?
  socialWorkflowWebhookUrl   String?
  trendWorkflowWebhookUrl    String?
  canvaWorkflowWebhookUrl    String?
  remotionWorkflowWebhookUrl String?
  metaAdsWorkflowWebhookUrl  String?
  webhookSecret              String?
  isEnabled                  Boolean  @default(false)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model MarketingCampaign {
  id                    String         @id @default(cuid())
  type                  CampaignType
  status                CampaignStatus @default(IDEA)
  title                 String
  goal                  String?
  platform              String?
  campaignBrief         String?
  approvedStrategy      String?
  approvedCaption       String?
  approvedHashtags      String?
  approvedCreativeNotes String?
  isTest                Boolean        @default(false)
  budget                Float?
  startDate             DateTime?
  endDate               DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  detailJobId    String?
  clientId       String?
  vehicleId      String?
  trendInsightId String?

  detailJob    DetailJob?    @relation(fields: [detailJobId], references: [id])
  client       Client?       @relation(fields: [clientId], references: [id])
  vehicle      Vehicle?      @relation(fields: [vehicleId], references: [id])
  trendInsight TrendInsight? @relation(fields: [trendInsightId], references: [id])

  assets           MarketingAsset[]
  workflowRuns     AutomationWorkflowRun[]
  performanceStats MarketingPerformanceStat[]
}

model MarketingAsset {
  id           String        @id @default(cuid())
  campaignId   String
  type         AssetType
  provider     AssetProvider
  url          String?
  thumbnailUrl String?
  title        String
  notes        String?
  status       AssetStatus   @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model AutomationWorkflowRun {
  id             String                 @id @default(cuid())
  campaignId     String?
  workflowType   AutomationWorkflowType
  status         AutomationRunStatus    @default(PENDING)
  n8nExecutionId String?
  inputPayload   Json?
  outputPayload  Json?
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  campaign MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model MarketingPerformanceStat {
  id          String   @id @default(cuid())
  campaignId  String
  platform    String
  postUrl     String?
  impressions Int      @default(0)
  reach       Int      @default(0)
  views       Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  saves       Int      @default(0)
  clicks      Int      @default(0)
  leads       Int      @default(0)
  spend       Float    @default(0)
  costPerLead Float?
  date        DateTime
  rawData     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}
